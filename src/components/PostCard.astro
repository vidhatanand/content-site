---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, cluster, tags } = post.data;
---

<article class="post-card">
  <div class="card-meta">
    <a href={`/${cluster}/`} class="cluster-tag">{cluster.replace(/-/g, ' ')}</a>
    <time datetime={pubDate.toISOString()}>
      {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
  </div>
  <h2><a href={`/blog/${post.id}/`}>{title}</a></h2>
  <p class="excerpt">{description}</p>
  {tags.length > 0 && (
    <div class="tags">
      {tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
    </div>
  )}
</article>

<style>
  .post-card {
    padding: 1.5rem 0;
    border-bottom: 1px solid #e5e7eb;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: #6b7280;
    margin-bottom: 0.5rem;
  }

  .cluster-tag {
    background: #eff6ff;
    color: #2563eb;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 500;
    text-transform: capitalize;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  h2 a {
    text-decoration: none;
    color: #111827;
  }

  h2 a:hover {
    color: #2563eb;
  }

  .excerpt {
    color: #4b5563;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .tag {
    background: #f3f4f6;
    color: #6b7280;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.75rem;
  }
</style>
