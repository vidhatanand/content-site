---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, cluster, tags, image, canonicalUrl } = post.data;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'ContentSite',
    logo: {
      '@type': 'ImageObject',
      url: `${Astro.site}favicon.svg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl ?? Astro.url.toString(),
  },
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  image={image}
  type="article"
  pubDate={pubDate}
  author={author}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="article">
    <header class="article-header">
      <div class="meta">
        <a href={`/${cluster}/`} class="cluster-tag">{cluster.replace(/-/g, ' ')}</a>
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
      <h1>{title}</h1>
      <p class="description">{description}</p>
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    {updatedDate && (
      <p class="updated">
        Last updated: <time datetime={updatedDate.toISOString()}>
          {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </p>
    )}
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 740px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: #6b7280;
  }

  .cluster-tag {
    background: #eff6ff;
    color: #2563eb;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 500;
    text-transform: capitalize;
  }

  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: #111827;
  }

  .description {
    font-size: 1.125rem;
    color: #4b5563;
    line-height: 1.7;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    background: #f3f4f6;
    color: #374151;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.8rem;
  }

  .prose :global(h2) { font-size: 1.5rem; font-weight: 700; margin: 2rem 0 0.75rem; }
  .prose :global(h3) { font-size: 1.25rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .prose :global(p) { margin-bottom: 1.25rem; color: #374151; }
  .prose :global(a) { color: #2563eb; }
  .prose :global(ul), .prose :global(ol) { margin: 1rem 0 1.25rem 1.5rem; }
  .prose :global(li) { margin-bottom: 0.375rem; color: #374151; }
  .prose :global(pre) { background: #1e293b; padding: 1.25rem; border-radius: 8px; overflow-x: auto; margin: 1.5rem 0; }
  .prose :global(code) { font-family: 'Fira Code', monospace; font-size: 0.875rem; }
  .prose :global(blockquote) { border-left: 4px solid #e5e7eb; padding-left: 1rem; color: #6b7280; font-style: italic; margin: 1.5rem 0; }

  .updated {
    margin-top: 2rem;
    font-size: 0.875rem;
    color: #9ca3af;
  }
</style>
