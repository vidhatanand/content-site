---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  image?: { src: string; alt: string };
  type?: 'website' | 'article';
  pubDate?: Date;
  author?: string;
}

const {
  title,
  description,
  canonicalUrl,
  image,
  type = 'website',
  pubDate,
  author,
} = Astro.props;

const siteUrl = import.meta.env.SITE ?? Astro.site?.toString() ?? '';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image ? new URL(image.src, siteUrl).toString() : `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {image && <meta property="og:image:alt" content={image.alt} />}
    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {author && <meta property="article:author" content={author} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-name">ContentSite</a>
        <ul>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/ai-content-creation/">AI Content</a></li>
          <li><a href="/topical-authority-seo/">Topical SEO</a></li>
          <li><a href="/b2b-saas-content/">B2B SaaS</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} ContentSite. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: system-ui, -apple-system, sans-serif;
    line-height: 1.6;
    color: #1a1a1a;
    background: #fff;
  }

  header {
    border-bottom: 1px solid #e5e7eb;
    padding: 1rem 2rem;
  }

  nav {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .site-name {
    font-weight: 700;
    font-size: 1.2rem;
    text-decoration: none;
    color: #1a1a1a;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    text-decoration: none;
    color: #4b5563;
    font-size: 0.95rem;
  }

  nav a:hover {
    color: #1a1a1a;
  }

  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem;
  }

  footer {
    border-top: 1px solid #e5e7eb;
    padding: 2rem;
    text-align: center;
    color: #6b7280;
    font-size: 0.875rem;
  }
</style>
